# Supabase (required for auth and tasks)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry (optional – for error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=

# Email — organization invite delivery (Resend: https://resend.com)
# Local / Vercel preview: when unset, invite links are logged and the UI can
# copy them (nothing is sent to the invitee's inbox).
# Vercel Production: set RESEND_API_KEY or creating an invite fails until it is
# configured (Production env in Vercel → Environment Variables).
RESEND_API_KEY=
# Sender for the From: header. Defaults to "Alino <noreply@alinoapp.com>" when
# unset. Use an address on a domain you have verified in Resend.
# Format: "name@domain" or "Display Name <name@domain>".
EMAIL_FROM=
