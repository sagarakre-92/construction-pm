# Supabase (required for auth and tasks)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry (optional – for error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=

# Email (optional – invitation delivery)
# When RESEND_API_KEY is unset, invitation emails are logged to the console
# instead of being delivered (suitable for dev). To enable real delivery, set
# this to a Resend API key (https://resend.com).
RESEND_API_KEY=
# Sender used in the From: header. Defaults to "ORAT <noreply@orat.app>" when
# unset. Format must be either "name@domain" or "Display Name <name@domain>".
EMAIL_FROM=
